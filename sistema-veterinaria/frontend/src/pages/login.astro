---
// Página de Login
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar Sesión - Veterinaria</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Segoe UI", system-ui, sans-serif; }

    .bg-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 16px;
      background: linear-gradient(120deg, #1e40af, #6d28d9, #be185d, #6d28d9, #1e40af);
      background-size: 300% 300%;
      animation: gradMove 8s ease infinite;
    }
    @keyframes gradMove {
      0%,100% { background-position: 0% 50%; }
      50%      { background-position: 100% 50%; }
    }

    .card-wrap { width: 100%; max-width: 460px; }

    .card {
      background: #fff;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,.4);
    }

    .card-header {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      padding: 52px 40px 44px;
      text-align: center;
    }
    .avatar {
      width: 88px; height: 88px;
      background: #fff;
      border-radius: 50%;
      margin: 0 auto 22px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 28px rgba(0,0,0,.25);
    }
    .card-header h1 { color: #fff; font-size: 30px; font-weight: 800; margin-bottom: 8px; }
    .card-header p  { color: rgba(255,255,255,.8); font-size: 15px; }

    .card-body { padding: 40px 40px 48px; }

    .alert {
      display: none;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 24px;
      font-size: 14px;
      font-weight: 500;
      align-items: center;
      gap: 10px;
    }
    .alert.show { display: flex; }
    .alert-err  { background: #fef2f2; border-left: 4px solid #ef4444; color: #b91c1c; }
    .alert-ok   { background: #f0fdf4; border-left: 4px solid #22c55e; color: #15803d; }

    .field { margin-bottom: 22px; }
    .field label { display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px; }
    .input-wrap { position: relative; }
    .input-icon {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      pointer-events: none; color: #9ca3af;
    }
    input[type="text"], input[type="password"] {
      width: 100%;
      padding: 14px 14px 14px 46px;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      font-size: 15px;
      outline: none;
      background: #f9fafb;
      transition: border-color .2s, box-shadow .2s;
      color: #111827;
    }
    input[type="text"]:focus, input[type="password"]:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 4px rgba(99,102,241,.18);
      background: #fff;
    }
    .btn-eye {
      position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: #9ca3af; padding: 0;
      display: flex; align-items: center;
    }
    .btn-eye:hover { color: #6366f1; }

    .btn-login {
      width: 100%; padding: 15px;
      border: none; border-radius: 12px;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: #fff; font-size: 16px; font-weight: 700;
      cursor: pointer; margin-top: 6px;
      box-shadow: 0 6px 24px rgba(99,102,241,.4);
      transition: transform .2s, box-shadow .2s, opacity .2s;
    }
    .btn-login:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(99,102,241,.5);
    }
    .btn-login:disabled { opacity: .6; cursor: not-allowed; }

    .demo-box {
      margin-top: 28px;
      padding: 16px 20px;
      background: linear-gradient(135deg, #eef2ff, #f5f3ff);
      border-radius: 12px;
      border: 1px solid #e0e7ff;
    }
    .demo-box h3 { text-align: center; font-size: 13px; font-weight: 700; color: #4338ca; margin-bottom: 12px; }
    .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .demo-item {
      background: #fff; border-radius: 8px; padding: 10px;
      border: 1px solid #e0e7ff; text-align: center;
    }
    .demo-item span { display: block; font-size: 11px; color: #6b7280; margin-bottom: 4px; }
    .demo-item strong { font-size: 16px; font-weight: 800; color: #4f46e5; }

    .footer { text-align: center; margin-top: 26px; }
    .footer p { color: rgba(255,255,255,.9); font-size: 13px; font-weight: 600; margin-bottom: 4px; }
    .footer small { color: rgba(255,255,255,.6); font-size: 12px; }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20%,60% { transform: translateX(-8px); }
      40%,80% { transform: translateX(8px); }
    }
    .shake { animation: shake .35s; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spin { animation: spin .8s linear infinite; display: inline-block; }
  </style>
</head>
<body>

<div class="bg-wrap">
  <div class="card-wrap">

    <div class="card">
      <!-- Header -->
      <div class="card-header">
        <div class="avatar">
          <svg width="46" height="46" fill="none" stroke="#4f46e5" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h1>¡Bienvenido!</h1>
        <p>Sistema de Gestión Veterinaria</p>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Error -->
        <div id="alert-err" class="alert alert-err">
          <svg width="20" height="20" fill="#ef4444" viewBox="0 0 20 20" style="flex-shrink:0">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <span id="alert-err-msg"></span>
        </div>

        <!-- Éxito -->
        <div id="alert-ok" class="alert alert-ok">
          <span class="spin"></span>
          <span>Autenticando, redirigiendo al panel...</span>
        </div>

        <!-- Formulario -->
        <form id="login-form">
          <div class="field">
            <label for="username">Usuario</label>
            <div class="input-wrap">
              <span class="input-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </span>
              <input type="text" id="username" name="username" placeholder="Ingresa tu usuario" autocomplete="username" required />
            </div>
          </div>

          <div class="field" style="margin-bottom:28px">
            <label for="password">Contraseña</label>
            <div class="input-wrap">
              <span class="input-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </span>
              <input type="password" id="password" name="password" placeholder="Ingresa tu contraseña" autocomplete="current-password" style="padding-right:48px" required />
              <button type="button" class="btn-eye" id="toggle-pass" tabindex="-1">
                <svg id="eye-on" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                <svg id="eye-off" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                </svg>
              </button>
            </div>
          </div>

          <button class="btn-login" type="submit" id="btn-submit">Iniciar Sesión</button>
        </form>

        <!-- Demo -->
        <div class="demo-box">
          <h3> Credenciales de prueba</h3>
          <div class="demo-grid">
            <div class="demo-item"><span>Usuario</span><strong>admin</strong></div>
            <div class="demo-item"><span>Contraseña</span><strong>admin123</strong></div>
          </div>
        </div>

      </div>
    </div>

    <div class="footer">
      <p>Sistema de Gestión Veterinaria  2026</p>
      <small>Desarrollado con FastAPI & Astro</small>
    </div>
  </div>
</div>

<script>
  function parseDetail(d) {
    if (!d) return 'Error al iniciar sesión';
    if (typeof d === 'string') return d;
    if (Array.isArray(d)) return d.map(x => x.msg || JSON.stringify(x)).join('. ');
    return JSON.stringify(d);
  }

  function showErr(msg) {
    var el = document.getElementById('alert-err');
    document.getElementById('alert-err-msg').textContent = msg;
    el.classList.add('show');
    document.getElementById('alert-ok').classList.remove('show');
    document.getElementById('login-form').classList.add('shake');
    setTimeout(() => document.getElementById('login-form').classList.remove('shake'), 400);
  }

  document.getElementById('toggle-pass').addEventListener('click', function() {
    var inp = document.getElementById('password');
    var isPass = inp.type === 'password';
    inp.type = isPass ? 'text' : 'password';
    document.getElementById('eye-on').style.display  = isPass ? 'none'  : 'block';
    document.getElementById('eye-off').style.display = isPass ? 'block' : 'none';
  });

  document.getElementById('login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var username = document.getElementById('username').value.trim();
    var password = document.getElementById('password').value;
    var btn = document.getElementById('btn-submit');

    document.getElementById('alert-err').classList.remove('show');
    document.getElementById('alert-ok').classList.remove('show');
    btn.disabled = true;
    btn.textContent = 'Autenticando...';

    try {
      var res = await fetch('http://localhost:8000/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: username, password: password })
      });

      var data = await res.json();
      console.log('Login response:', res.status, data);

      if (!res.ok) {
        throw new Error(parseDetail(data.detail) || 'Credenciales incorrectas');
      }
      if (!data.access_token) {
        throw new Error('No se recibió token del servidor');
      }

      localStorage.setItem('token', data.access_token);
      document.getElementById('alert-ok').classList.add('show');
      setTimeout(() => { window.location.href = '/dashboard'; }, 600);

    } catch(err) {
      console.error('Error login:', err);
      showErr(err instanceof Error ? err.message : 'Error de conexión');
      btn.disabled = false;
      btn.textContent = 'Iniciar Sesión';
    }
  });

  if (localStorage.getItem('token')) {
    window.location.href = '/dashboard';
  }
</script>

</body>
</html>
