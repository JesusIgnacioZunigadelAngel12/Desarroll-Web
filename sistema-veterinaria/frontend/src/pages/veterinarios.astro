---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Veterinarios">

<!-- Toolbar -->
<div class="page-card-header" style="background:#fff;border-radius:16px 16px 0 0;padding:20px 24px;border-bottom:1px solid #f3f4f6;margin-bottom:0">
  <span class="page-card-title">Equipo Veterinario</span>
  <div style="display:flex;gap:10px;align-items:center">
    <div class="search-wrap">
      <svg class="search-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
      </svg>
      <input type="text" id="search-input" class="search-input" placeholder="Buscar veterinario..." />
    </div>
    <select id="filtro-activo" class="filter-select">
      <option value="">Todos</option>
      <option value="true">Activos</option>
      <option value="false">Inactivos</option>
    </select>
    <button id="add-vet-btn" class="btn-primary">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Nuevo Veterinario
    </button>
  </div>
</div>

<!-- Grid tarjetas -->
<div class="page-card" style="border-radius:0 0 16px 16px;padding:24px">
  <div id="vet-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px"></div>
</div>

<!-- Modal -->
<div id="vet-modal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="modal-title">Nuevo Veterinario</h3>
      <p>Completa los datos del profesional</p>
    </div>
    <div class="modal-body">
      <form id="vet-form">
        <input type="hidden" id="vet-id" />
        <div class="form-grid">

          <div class="form-group">
            <label class="form-label">Nombre *</label>
            <input type="text" id="v-nombre" required class="form-input" placeholder="Nombre" />
          </div>
          <div class="form-group">
            <label class="form-label">Apellido *</label>
            <input type="text" id="v-apellido" required class="form-input" placeholder="Apellido" />
          </div>

          <div class="form-group full">
            <label class="form-label">Especialidad</label>
            <input type="text" id="v-especialidad" class="form-input"
              placeholder="Ej: Cirugía, Dermatología, Medicina general..." />
          </div>

          <div class="form-group">
            <label class="form-label">Teléfono</label>
            <input type="text" id="v-telefono" class="form-input" placeholder="09xxxxxxxx" />
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" id="v-email" class="form-input" placeholder="correo@ejemplo.com" />
          </div>

          <div class="form-group full">
            <label class="form-label">Estado</label>
            <select id="v-activo" class="form-select">
              <option value="true">Activo</option>
              <option value="false">Inactivo</option>
            </select>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button type="button" id="cancel-btn" class="btn-secondary">Cancelar</button>
      <button type="submit" form="vet-form" class="btn-primary">Guardar</button>
    </div>
  </div>
</div>

<script>
const API_URL = 'http://localhost:8000';
const token   = localStorage.getItem('token');
const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };

let veterinarios = [];

// ── Cargar ────────────────────────────────────────────
async function loadVets() {
  const res = await fetch(`${API_URL}/api/veterinarios`, { headers });
  veterinarios = await res.json();
  renderGrid();
}

// ── Render tarjetas ───────────────────────────────────
function renderGrid() {
  const q      = document.getElementById('search-input').value.toLowerCase();
  const filtro = document.getElementById('filtro-activo').value;

  const filtered = veterinarios.filter(v => {
    const matchQ = !q ||
      `${v.nombre} ${v.apellido}`.toLowerCase().includes(q) ||
      (v.especialidad || '').toLowerCase().includes(q);
    const matchA = !filtro || String(v.activo) === filtro;
    return matchQ && matchA;
  });

  const grid = document.getElementById('vet-grid');
  if (!filtered.length) {
    grid.innerHTML = '<p class="alert-empty" style="grid-column:1/-1">No se encontraron veterinarios</p>';
    return;
  }

  grid.innerHTML = filtered.map(v => `
    <div style="background:#fff;border:1.5px solid #e5e7eb;border-radius:14px;padding:20px;
      transition:border-color .15s,box-shadow .15s;position:relative"
      onmouseenter="this.style.borderColor='#a5b4fc';this.style.boxShadow='0 4px 16px rgba(99,102,241,.12)'"
      onmouseleave="this.style.borderColor='#e5e7eb';this.style.boxShadow=''"
    >
      <!-- Avatar + estado -->
      <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">
        <div style="width:48px;height:48px;border-radius:50%;
          background:linear-gradient(135deg,#4f46e5,#7c3aed);
          display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:18px">
          ${v.nombre[0]}${v.apellido[0]}
        </div>
        <span class="badge ${v.activo ? 'badge-green' : 'badge-gray'}">${v.activo ? 'Activo' : 'Inactivo'}</span>
      </div>

      <p style="font-weight:700;font-size:15px;color:#111827;margin:0 0 2px">${v.nombre} ${v.apellido}</p>
      ${v.especialidad ? `<p style="font-size:12px;color:#6366f1;font-weight:600;margin:0 0 10px">${v.especialidad}</p>` : '<p style="margin:0 0 10px"></p>'}

      ${v.telefono ? `<p style="font-size:12px;color:#6b7280;margin:0 0 4px">📞 ${v.telefono}</p>` : ''}
      ${v.email    ? `<p style="font-size:12px;color:#6b7280;margin:0 0 10px">✉️ ${v.email}</p>`    : ''}

      <div style="display:flex;gap:8px;margin-top:14px;border-top:1px solid #f3f4f6;padding-top:12px">
        <button class="btn-edit" style="flex:1" onclick="editVet(${v.id})">Editar</button>
        <button class="btn-danger" onclick="deleteVet(${v.id})">Eliminar</button>
      </div>
    </div>
  `).join('');
}

// ── Modal ─────────────────────────────────────────────
const modal = document.getElementById('vet-modal');
const form  = document.getElementById('vet-form');

function resetModal() {
  form.reset();
  document.getElementById('vet-id').value = '';
  document.getElementById('v-activo').value = 'true';
}

document.getElementById('add-vet-btn').addEventListener('click', () => {
  resetModal();
  document.getElementById('modal-title').textContent = 'Nuevo Veterinario';
  modal.classList.add('open');
});
document.getElementById('cancel-btn').addEventListener('click', () => modal.classList.remove('open'));
modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });

window.editVet = (id) => {
  const v = veterinarios.find(x => x.id === id); if (!v) return;
  resetModal();
  document.getElementById('modal-title').textContent = 'Editar Veterinario';
  document.getElementById('vet-id').value      = id;
  document.getElementById('v-nombre').value    = v.nombre;
  document.getElementById('v-apellido').value  = v.apellido;
  document.getElementById('v-especialidad').value = v.especialidad || '';
  document.getElementById('v-telefono').value  = v.telefono || '';
  document.getElementById('v-email').value     = v.email || '';
  document.getElementById('v-activo').value    = String(v.activo);
  modal.classList.add('open');
};

window.deleteVet = async (id) => {
  const v = veterinarios.find(x => x.id === id);
  if (!confirm(`¿Eliminar a ${v?.nombre} ${v?.apellido}? Esta acción no se puede deshacer.`)) return;
  await fetch(`${API_URL}/api/veterinarios/${id}`, { method: 'DELETE', headers });
  await loadVets();
};

// ── Guardar ───────────────────────────────────────────
form.addEventListener('submit', async e => {
  e.preventDefault();
  const id = document.getElementById('vet-id').value;
  const data = {
    nombre:       document.getElementById('v-nombre').value.trim(),
    apellido:     document.getElementById('v-apellido').value.trim(),
    especialidad: document.getElementById('v-especialidad').value.trim() || null,
    telefono:     document.getElementById('v-telefono').value.trim() || null,
    email:        document.getElementById('v-email').value.trim() || null,
    activo:       document.getElementById('v-activo').value === 'true',
  };
  try {
    await fetch(id ? `${API_URL}/api/veterinarios/${id}` : `${API_URL}/api/veterinarios`, {
      method: id ? 'PUT' : 'POST', headers, body: JSON.stringify(data)
    });
    modal.classList.remove('open');
    await loadVets();
  } catch { alert('Error al guardar'); }
});

// ── Filtros ───────────────────────────────────────────
document.getElementById('search-input').addEventListener('input', renderGrid);
document.getElementById('filtro-activo').addEventListener('change', renderGrid);

loadVets();
</script>
</DashboardLayout>
