---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Mascotas">
  <div class="page-card">
    <div class="page-card-header">
      <span class="page-card-title">Mascotas registradas</span>
      <div style="display:flex;gap:12px;align-items:center">
        <div class="search-wrap">
          <svg class="search-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
          </svg>
          <input type="text" id="search-input" class="search-input" placeholder="Buscar mascotas..." />
        </div>
        <button id="add-mascota-btn" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Nueva Mascota
        </button>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Mascota</th><th>Especie / Raza</th><th>Propietario</th>
            <th>Edad / Peso</th><th>Sexo</th><th style="text-align:right">Acciones</th>
          </tr>
        </thead>
        <tbody id="mascotas-tbody">
          <tr><td colspan="6" class="alert-empty">Cargando mascotas...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="mascota-modal" class="modal-overlay">
    <div class="modal-box modal-box-lg">
      <div class="modal-header">
        <h3 id="modal-title">Nueva Mascota</h3>
        <p>Completa los datos de la mascota</p>
      </div>
      <div class="modal-body">
        <form id="mascota-form">
          <input type="hidden" id="mascota-id" />
          <div class="form-grid">
            <div class="form-group" style="position:relative">
              <label class="form-label">Propietario *</label>
              <input type="hidden" id="cliente_id" required />
              <input type="text" id="cliente-search" class="form-input" placeholder="Buscar por nombre o teléfono..." autocomplete="off" />
              <div id="cliente-dropdown" style="display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border:1.5px solid #6366f1;border-top:none;border-radius:0 0 10px 10px;max-height:200px;overflow-y:auto;z-index:100;box-shadow:0 8px 24px rgba(0,0,0,.12);"></div>
            </div>
            <div class="form-group">
              <label class="form-label">Nombre *</label>
              <input type="text" id="nombre" required class="form-input" placeholder="Nombre de la mascota" />
            </div>
            <div class="form-group">
              <label class="form-label">Especie *</label>
              <input type="text" id="especie" required class="form-input" placeholder="Ej: Perro, Gato..." />
            </div>
            <div class="form-group">
              <label class="form-label">Raza</label>
              <input type="text" id="raza" class="form-input" placeholder="Raza" />
            </div>
            <div class="form-group">
              <label class="form-label">Sexo</label>
              <select id="sexo" class="form-select">
                <option value="">Sin especificar</option>
                <option value="Macho">Macho</option>
                <option value="Hembra">Hembra</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Edad (años)</label>
              <input type="number" id="edad" min="0" step="0.5" class="form-input" placeholder="Ej: 2" />
            </div>
            <div class="form-group">
              <label class="form-label">Peso (kg)</label>
              <input type="number" id="peso" min="0" step="0.1" class="form-input" placeholder="Ej: 5.5" />
            </div>
            <div class="form-group">
              <label class="form-label">Color</label>
              <input type="text" id="color" class="form-input" placeholder="Color del pelaje" />
            </div>
            <div class="form-group full">
              <label class="form-label">Observaciones</label>
              <textarea id="observaciones" class="form-textarea" placeholder="Alergias, condiciones especiales..."></textarea>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" id="cancel-btn" class="btn-secondary">Cancelar</button>
        <button type="submit" form="mascota-form" class="btn-primary">Guardar Mascota</button>
      </div>
    </div>
  </div>

  <script>
    const API_URL = 'http://localhost:8000';
    const token = localStorage.getItem('token');
    const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };
    let mascotas = [], clientesMap = {}, clientesList = [];

    // ── Autocomplete propietario ──
    const clienteSearch  = document.getElementById('cliente-search');
    const clienteHidden  = document.getElementById('cliente_id');
    const clienteDrop    = document.getElementById('cliente-dropdown');

    function renderDrop(items) {
      if (!items.length) {
        clienteDrop.innerHTML = '<p style="padding:10px 14px;font-size:13px;color:#9ca3af">Sin resultados</p>';
      } else {
        clienteDrop.innerHTML = items.slice(0, 50).map(c => `
          <div data-id="${c.id}" style="padding:10px 14px;cursor:pointer;font-size:13px;border-bottom:1px solid #f3f4f6;transition:background .1s"
               onmouseenter="this.style.background='#f5f3ff'" onmouseleave="this.style.background=''"
               onmousedown="selectCliente(${c.id},'${c.nombre} ${c.apellido}')">
            <strong>${c.nombre} ${c.apellido}</strong>
            <span style="color:#9ca3af;margin-left:8px">${c.telefono}</span>
          </div>`).join('');
      }
      clienteDrop.style.display = 'block';
    }

    window.selectCliente = (id, nombre) => {
      clienteHidden.value = id;
      clienteSearch.value = nombre;
      clienteDrop.style.display = 'none';
      clienteSearch.style.borderColor = '#10b981';
    };

    clienteSearch.addEventListener('input', () => {
      const q = clienteSearch.value.toLowerCase().trim();
      clienteHidden.value = '';
      clienteSearch.style.borderColor = '';
      if (!q) { clienteDrop.style.display = 'none'; return; }
      const filtered = clientesList.filter(c =>
        `${c.nombre} ${c.apellido}`.toLowerCase().includes(q) ||
        c.telefono.includes(q)
      );
      renderDrop(filtered);
    });

    clienteSearch.addEventListener('focus', () => {
      const q = clienteSearch.value.toLowerCase().trim();
      const items = q
        ? clientesList.filter(c => `${c.nombre} ${c.apellido}`.toLowerCase().includes(q) || c.telefono.includes(q))
        : clientesList;
      renderDrop(items);
    });

    document.addEventListener('click', e => {
      if (!clienteSearch.contains(e.target) && !clienteDrop.contains(e.target))
        clienteDrop.style.display = 'none';
    });

    async function loadClientes() {
      const res = await fetch(`${API_URL}/api/clientes`, { headers });
      clientesList = await res.json();
      clientesList.forEach(c => clientesMap[c.id] = `${c.nombre} ${c.apellido}`);
    }
    async function loadMascotas(search = '') {
      try {
        const url = search ? `${API_URL}/api/mascotas?search=${encodeURIComponent(search)}` : `${API_URL}/api/mascotas`;
        const res = await fetch(url, { headers });
        mascotas = await res.json();
        renderMascotas();
      } catch (e) { console.error(e); }
    }
    function renderMascotas() {
      const tbody = document.getElementById('mascotas-tbody');
      if (!mascotas.length) { tbody.innerHTML = '<tr><td colspan="6" class="alert-empty">No se encontraron mascotas</td></tr>'; return; }
      tbody.innerHTML = mascotas.map(m => `
        <tr>
          <td><p class="cell-name">${m.nombre}</p><p class="cell-sub">${m.color || ''}</p></td>
          <td><p class="cell-name">${m.especie}</p><p class="cell-sub">${m.raza || ''}</p></td>
          <td>${clientesMap[m.cliente_id] || '<span style="color:#d1d5db"></span>'}</td>
          <td>${m.edad ? m.edad + ' años' : ''} / ${m.peso ? m.peso + ' kg' : ''}</td>
          <td>${m.sexo ? `<span class="badge ${m.sexo==='Macho'?'badge-blue':'badge-purple'}">${m.sexo}</span>` : ''}</td>
          <td style="text-align:right">
            <button class="btn-edit" onclick="editMascota(${m.id})">Editar</button>
            <button class="btn-danger" onclick="deleteMascota(${m.id})" style="margin-left:6px">Eliminar</button>
          </td>
        </tr>`).join('');
    }
    const modal = document.getElementById('mascota-modal');
    const form = document.getElementById('mascota-form');
    document.getElementById('add-mascota-btn').addEventListener('click', () => {
      form.reset();
      document.getElementById('mascota-id').value = '';
      document.getElementById('cliente_id').value = '';
      clienteSearch.value = '';
      clienteSearch.style.borderColor = '';
      clienteDrop.style.display = 'none';
      document.getElementById('modal-title').textContent = 'Nueva Mascota';
      modal.classList.add('open');
    });
    document.getElementById('cancel-btn').addEventListener('click', () => modal.classList.remove('open'));
    modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });
    let st;
    document.getElementById('search-input').addEventListener('input', e => {
      clearTimeout(st); st = setTimeout(() => loadMascotas(e.target.value), 300);
    });
    form.addEventListener('submit', async e => {
      e.preventDefault();
      if (!clienteHidden.value) {
        clienteSearch.style.borderColor = '#dc2626';
        clienteSearch.focus();
        clienteSearch.placeholder = 'Debes seleccionar un propietario de la lista';
        return;
      }
      const data = {
        cliente_id: parseInt(document.getElementById('cliente_id').value),
        nombre: document.getElementById('nombre').value,
        especie: document.getElementById('especie').value,
        raza: document.getElementById('raza').value || null,
        sexo: document.getElementById('sexo').value || null,
        edad: parseFloat(document.getElementById('edad').value) || null,
        peso: parseFloat(document.getElementById('peso').value) || null,
        color: document.getElementById('color').value || null,
        observaciones: document.getElementById('observaciones').value || null,
      };
      const id = document.getElementById('mascota-id').value;
      try {
        await fetch(id ? `${API_URL}/api/mascotas/${id}` : `${API_URL}/api/mascotas`, {
          method: id ? 'PUT' : 'POST', headers, body: JSON.stringify(data)
        });
        modal.classList.remove('open'); loadMascotas();
      } catch { alert('Error al guardar mascota'); }
    });
    window.editMascota = id => {
      const m = mascotas.find(x => x.id === id); if (!m) return;
      document.getElementById('mascota-id').value = id;
      clienteHidden.value = m.cliente_id;
      clienteSearch.value = clientesMap[m.cliente_id] || '';
      clienteSearch.style.borderColor = '#10b981';
      clienteDrop.style.display = 'none';
      document.getElementById('nombre').value = m.nombre;
      document.getElementById('especie').value = m.especie;
      document.getElementById('raza').value = m.raza || '';
      document.getElementById('sexo').value = m.sexo || '';
      document.getElementById('edad').value = m.edad || '';
      document.getElementById('peso').value = m.peso || '';
      document.getElementById('color').value = m.color || '';
      document.getElementById('observaciones').value = m.observaciones || '';
      document.getElementById('modal-title').textContent = 'Editar Mascota';
      modal.classList.add('open');
    };
    window.deleteMascota = async id => {
      if (!confirm('¿Eliminar esta mascota?')) return;
      try { await fetch(`${API_URL}/api/mascotas/${id}`, { method: 'DELETE', headers }); loadMascotas(); }
      catch { alert('Error al eliminar mascota'); }
    };
    loadClientes().then(() => loadMascotas());
  </script>
</DashboardLayout>
