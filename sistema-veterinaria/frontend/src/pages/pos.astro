---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Punto de Venta">
<style>
  .pos-grid { display: grid; grid-template-columns: 1fr 360px; gap: 20px; }
  .prod-card {
    background:#fff; border-radius:12px; padding:16px;
    box-shadow:0 1px 3px rgba(0,0,0,.07); cursor:pointer; border:2px solid transparent;
    transition:border-color .15s, box-shadow .15s, transform .15s;
    text-align:left;
  }
  .prod-card:hover:not(:disabled) { border-color:#6366f1; box-shadow:0 4px 12px rgba(99,102,241,.2); transform:translateY(-2px); }
  .prod-card:disabled { opacity:.5; cursor:not-allowed; }
  .prod-name { font-weight:700; color:#111827; font-size:14px; margin-bottom:4px; }
  .prod-code { font-size:11px; color:#9ca3af; margin-bottom:8px; }
  .prod-price { font-size:18px; font-weight:800; color:#059669; }
  .prod-stock { font-size:11px; margin-top:4px; }
  .cart-item {
    display:flex; align-items:center; justify-content:space-between;
    padding:10px 12px; background:#f9fafb; border-radius:10px; margin-bottom:8px;
  }
  .qty-btn {
    width:26px; height:26px; border-radius:6px; border:none; cursor:pointer;
    background:#e5e7eb; color:#374151; font-weight:700; font-size:14px;
    display:flex; align-items:center; justify-content:center;
    transition:background .1s;
  }
  .qty-btn:hover { background:#d1d5db; }
  .qty-btn.remove { background:#fee2e2; color:#dc2626; }
  .qty-btn.remove:hover { background:#fecaca; }
  .totals-row { display:flex; justify-content:space-between; font-size:14px; padding:4px 0; }
  .totals-total { font-size:22px; font-weight:800; color:#059669; }
</style>

<div class="pos-grid">
  <!-- Productos panel -->
  <div>
    <div class="page-card" style="margin-bottom:16px">
      <div style="padding:16px 20px">
        <div class="search-wrap" style="width:100%">
          <svg class="search-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
          </svg>
          <input type="text" id="search-producto" class="search-input" style="width:100%" placeholder="Buscar producto por nombre o código..." />
        </div>
      </div>
    </div>
    <div id="productos-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
      <div style="grid-column:1/-1;text-align:center;padding:40px;color:#9ca3af">Cargando productos...</div>
    </div>
  </div>

  <!-- Cart panel -->
  <div>
    <div class="page-card" style="position:sticky;top:20px">
      <div class="page-card-header">
        <span class="page-card-title">Carrito de Venta</span>
      </div>
      <div style="padding:16px 20px">
        <!-- Cliente -->
        <div class="form-group" style="margin-bottom:14px">
          <label class="form-label">Cliente (opcional)</label>
          <select id="cliente-select" class="form-select"><option value="">Sin cliente</option></select>
        </div>
        <!-- Items -->
        <div id="cart-items" style="min-height:80px;max-height:260px;overflow-y:auto;margin-bottom:14px">
          <p style="text-align:center;color:#9ca3af;font-size:13px;padding:24px 0">Carrito vacío</p>
        </div>
        <!-- Totales -->
        <div style="border-top:1px solid #f3f4f6;padding-top:12px;margin-bottom:14px">
          <div class="totals-row"><span>Subtotal</span><span id="subtotal">$0.00</span></div>
          <div class="totals-row" style="align-items:center">
            <span>Descuento</span>
            <input type="number" id="descuento" value="0" min="0" step="0.01"
              style="width:80px;padding:4px 8px;border:1.5px solid #e5e7eb;border-radius:8px;text-align:right;font-size:13px;outline:none" />
          </div>
          <div class="totals-row" style="margin-top:8px;border-top:1px solid #f3f4f6;padding-top:8px">
            <span style="font-weight:700">Total</span>
            <span id="total" class="totals-total">$0.00</span>
          </div>
        </div>
        <!-- Método pago -->
        <div class="form-group" style="margin-bottom:12px">
          <label class="form-label">Método de Pago</label>
          <select id="metodo-pago" class="form-select">
            <option value="Efectivo">Efectivo</option>
            <option value="Tarjeta">Tarjeta</option>
            <option value="Transferencia">Transferencia</option>
          </select>
        </div>
        <!-- Notas -->
        <div class="form-group" style="margin-bottom:16px">
          <label class="form-label">Notas</label>
          <textarea id="notas" rows="2" class="form-textarea" placeholder="Notas adicionales..."></textarea>
        </div>
        <!-- Botones -->
        <button id="finalizar-venta-btn" class="btn-primary" style="width:100%;justify-content:center;padding:13px;font-size:15px" disabled>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Finalizar Venta
        </button>
        <button id="limpiar-carrito-btn" class="btn-secondary" style="width:100%;justify-content:center;margin-top:8px">
          Limpiar Carrito
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Success Modal -->
<div id="success-modal" class="modal-overlay">
  <div class="modal-box" style="max-width:400px;text-align:center">
    <div class="modal-header" style="background:linear-gradient(135deg,#059669,#10b981)">
      <h3>¡Venta Exitosa!</h3>
      <p>La venta fue procesada correctamente</p>
    </div>
    <div class="modal-body" style="padding:32px 28px">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.5" style="margin:0 auto 16px">
        <circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/>
      </svg>
      <p id="venta-codigo" style="color:#6b7280;margin-bottom:8px;font-size:14px"></p>
      <p id="venta-total" style="font-size:36px;font-weight:800;color:#059669"></p>
    </div>
    <div class="modal-footer" style="justify-content:center">
      <button id="close-modal-btn" class="btn-primary" style="justify-content:center;width:100%">Aceptar</button>
    </div>
  </div>
</div>

  <script>
    const API_URL = 'http://localhost:8000';
    const token = localStorage.getItem('token');
    const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };
    let productos = [], carrito = [], clientes = [];
    async function loadProductos() {
      try {
        const res = await fetch(`${API_URL}/api/productos?activo=true`, { headers });
        productos = await res.json();
        renderProductos();
      } catch (e) { console.error(e); }
    }
    async function loadClientes() {
      try {
        const res = await fetch(`${API_URL}/api/clientes`, { headers });
        clientes = await res.json();
        const sel = document.getElementById('cliente-select');
        sel.innerHTML = '<option value="">Sin cliente</option>' +
          clientes.map(c => `<option value="${c.id}">${c.nombre} ${c.apellido}</option>`).join('');
      } catch (e) { console.error(e); }
    }
    function renderProductos(search = '') {
      const grid = document.getElementById('productos-grid');
      const filtered = search
        ? productos.filter(p => p.nombre.toLowerCase().includes(search.toLowerCase()) || p.codigo.toLowerCase().includes(search.toLowerCase()))
        : productos;
      if (!filtered.length) { grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#9ca3af">No se encontraron productos</div>'; return; }
      grid.innerHTML = filtered.map(p => `
        <button class="prod-card" onclick="addToCart(${p.id})" ${p.stock <= 0 ? 'disabled' : ''}>
          <p class="prod-name">${p.nombre}</p>
          <p class="prod-code">${p.codigo}</p>
          <p class="prod-price">$${p.precio.toFixed(2)}</p>
          <p class="prod-stock" style="color:${p.stock <= p.stock_minimo ? '#dc2626' : '#9ca3af'}">Stock: ${p.stock}</p>
        </button>`).join('');
    }
    window.addToCart = id => {
      const p = productos.find(x => x.id === id);
      if (!p || p.stock <= 0) return;
      const ex = carrito.find(i => i.producto_id === id);
      if (ex) {
        if (ex.cantidad >= p.stock) { alert('No hay suficiente stock'); return; }
        ex.cantidad++;
      } else {
        carrito.push({ producto_id: id, nombre: p.nombre, precio_unitario: p.precio, cantidad: 1, stock_disponible: p.stock });
      }
      renderCarrito();
    };
    function renderCarrito() {
      const c = document.getElementById('cart-items');
      const btn = document.getElementById('finalizar-venta-btn');
      if (!carrito.length) {
        c.innerHTML = '<p style="text-align:center;color:#9ca3af;font-size:13px;padding:24px 0">Carrito vacío</p>';
        btn.disabled = true; updateTotales(); return;
      }
      btn.disabled = false;
      c.innerHTML = carrito.map((item, i) => `
        <div class="cart-item">
          <div style="flex:1;min-width:0">
            <p style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${item.nombre}</p>
            <p style="font-size:11px;color:#9ca3af">$${item.precio_unitario.toFixed(2)} c/u</p>
          </div>
          <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">
            <button class="qty-btn" onclick="updateQuantity(${i},-1)"></button>
            <span style="width:22px;text-align:center;font-weight:700;font-size:14px">${item.cantidad}</span>
            <button class="qty-btn" onclick="updateQuantity(${i},1)">+</button>
            <button class="qty-btn remove" onclick="removeFromCart(${i})"></button>
          </div>
        </div>`).join('');
      updateTotales();
    }
    window.updateQuantity = (i, d) => {
      const item = carrito[i], nq = item.cantidad + d;
      if (nq <= 0) carrito.splice(i, 1);
      else if (nq <= item.stock_disponible) item.cantidad = nq;
      else { alert('No hay suficiente stock'); return; }
      renderCarrito();
    };
    window.removeFromCart = i => { carrito.splice(i, 1); renderCarrito(); };
    function updateTotales() {
      const sub = carrito.reduce((s, i) => s + i.cantidad * i.precio_unitario, 0);
      const desc = parseFloat(document.getElementById('descuento').value) || 0;
      document.getElementById('subtotal').textContent = `$${sub.toFixed(2)}`;
      document.getElementById('total').textContent = `$${Math.max(0, sub - desc).toFixed(2)}`;
    }
    document.getElementById('descuento').addEventListener('input', updateTotales);
    document.getElementById('search-producto').addEventListener('input', e => renderProductos(e.target.value));
    document.getElementById('limpiar-carrito-btn').addEventListener('click', () => {
      if (!carrito.length || confirm('¿Limpiar el carrito?')) { carrito = []; renderCarrito(); }
    });
    document.getElementById('finalizar-venta-btn').addEventListener('click', async () => {
      if (!carrito.length) return;
      const clienteId = document.getElementById('cliente-select').value;
      const metodoPago = document.getElementById('metodo-pago').value;
      const descuento = parseFloat(document.getElementById('descuento').value) || 0;
      const notas = document.getElementById('notas').value;
      const venta = {
        cliente_id: clienteId ? parseInt(clienteId) : null,
        metodo_pago: metodoPago, descuento, notas,
        detalles: carrito.map(i => ({ producto_id: i.producto_id, cantidad: i.cantidad, precio_unitario: i.precio_unitario }))
      };
      try {
        const res = await fetch(`${API_URL}/api/ventas`, { method:'POST', headers, body: JSON.stringify(venta) });
        const result = await res.json();
        document.getElementById('venta-codigo').textContent = `Código: ${result.codigo_venta}`;
        document.getElementById('venta-total').textContent = `$${result.total.toFixed(2)}`;
        document.getElementById('success-modal').classList.add('open');
        carrito = []; renderCarrito();
        document.getElementById('descuento').value = '0';
        document.getElementById('notas').value = '';
        document.getElementById('cliente-select').value = '';
        loadProductos();
      } catch (e) { alert('Error al procesar la venta: ' + e.message); }
    });
    document.getElementById('close-modal-btn').addEventListener('click', () =>
      document.getElementById('success-modal').classList.remove('open'));
    loadProductos(); loadClientes();
  </script>
</DashboardLayout>
