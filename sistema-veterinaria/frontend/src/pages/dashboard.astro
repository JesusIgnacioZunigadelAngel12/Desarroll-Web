---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard">

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon stat-icon-green">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="stat-label">Ventas Hoy</p>
        <p id="ventas-hoy" class="stat-value">-</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon stat-icon-blue">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <p class="stat-label">Total Clientes</p>
        <p id="total-clientes" class="stat-value">-</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon stat-icon-purple">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
      <div>
        <p class="stat-label">Productos</p>
        <p id="total-productos" class="stat-value">-</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon stat-icon-amber">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"/>
        </svg>
      </div>
      <div>
        <p class="stat-label">Mascotas</p>
        <p id="total-mascotas" class="stat-value">-</p>
      </div>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="page-card" style="margin-bottom:24px">
    <div class="page-card-header">
      <span class="page-card-title">Acciones Rápidas</span>
    </div>
    <div style="padding:20px 24px">
      <div class="quick-grid">
        <a href="/pos" class="quick-card">
          <div class="quick-icon stat-icon-green">
            <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <p class="quick-label">Nueva Venta</p>
          <p class="quick-sub">Punto de venta rápido</p>
        </a>
        <a href="/clientes" class="quick-card">
          <div class="quick-icon stat-icon-blue">
            <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <p class="quick-label">Nuevo Cliente</p>
          <p class="quick-sub">Registrar cliente</p>
        </a>
        <a href="/productos" class="quick-card">
          <div class="quick-icon stat-icon-purple">
            <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <p class="quick-label">Inventario</p>
          <p class="quick-sub">Gestionar productos</p>
        </a>
      </div>
    </div>
  </div>

  <!-- Low stock -->
  <div class="page-card">
    <div class="page-card-header">
      <span class="page-card-title">Productos con Stock Bajo</span>
      <span class="badge badge-amber">Requiere atención</span>
    </div>
    <div style="padding:20px 24px" id="low-stock-container">
      <p class="alert-empty">Cargando...</p>
    </div>
  </div>

  <script>
    async function loadDashboard() {
      const API_URL = 'http://localhost:8000';
      const token = localStorage.getItem('token');
      const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };
      try {
        const statsRes = await fetch(`${API_URL}/api/ventas/estadisticas`, { headers });
        const stats = await statsRes.json();
        document.getElementById('ventas-hoy').textContent = stats.ventas_hoy || '0';

        const [clientesRes, productosRes, mascotasRes] = await Promise.all([
          fetch(`${API_URL}/api/clientes`, { headers }),
          fetch(`${API_URL}/api/productos`, { headers }),
          fetch(`${API_URL}/api/mascotas`, { headers })
        ]);
        const clientes  = await clientesRes.json();
        const productos = await productosRes.json();
        const mascotas  = await mascotasRes.json();

        document.getElementById('total-clientes').textContent  = clientes.length;
        document.getElementById('total-productos').textContent = productos.length;
        document.getElementById('total-mascotas').textContent  = mascotas.length;

        const lowStock = productos.filter(p => p.requiere_reposicion);
        const c = document.getElementById('low-stock-container');
        if (lowStock.length === 0) {
          c.innerHTML = '<p class="alert-empty" style="color:#16a34a;padding:20px"> Todos los productos tienen stock suficiente</p>';
        } else {
          c.innerHTML = lowStock.map(p => `
            <div class="stock-item">
              <div>
                <p style="font-weight:700;color:#111827;font-size:14px">${p.nombre}</p>
                <p style="font-size:12px;color:#9ca3af;margin-top:2px">Código: ${p.codigo}</p>
              </div>
              <div style="text-align:right">
                <span class="badge badge-red">Stock: ${p.stock}</span>
                <p style="font-size:12px;color:#9ca3af;margin-top:4px">Mínimo: ${p.stock_minimo}</p>
              </div>
            </div>
          `).join('');
        }
      } catch (err) { console.error(err); }
    }
    loadDashboard();
  </script>
</DashboardLayout>
